# LLM配置
LLM_MODEL_ID=deepseek-v4-pro
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置（允许哪些前端地址访问）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志级别
LOG_LEVEL=INFO

# Unsplash图片服务（可选）
UNSPLASH_ACCESS_KEY=""
UNSPLASH_SECRET_KEY=""

# 高德地图API密钥
AMAP_API_KEY=your_amap_api_key_here